{
  "manifest_version": 3,
  "name": "Yet Another Site Blocker",
  "version": "2.2",
  "description": "Website Blockers suck. This one doesn't. No ads, no subscription, no  popups, no BS. Just block websites and get on with your life.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "alarms",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "js/background.js"
  },
  "declarative_net_request": {
    "rule_resources": []
  },
  "options_page": "html/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "html/blocked.html",
        "js/blocked.js",
        "js/blocked-page.js",
        "js/rule-engine.js",
        "css/blocked.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Yet Another Site Blocker Settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
